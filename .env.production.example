# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example
# In Amplify Hosting, set these in the Console under
#   App settings → Environment variables.
# Never add real values here — this file is committed as documentation only.
# ─────────────────────────────────────────────────────────────────────────────

# Set automatically by the Amplify Hosting build pipeline.
# AWS_BRANCH=main
# AWS_APP_ID=<your-amplify-app-id>

# Lambda secrets are stored in Secrets Manager via:
#   npx ampx secret set EXTERNAL_API_KEY
# and referenced in amplify/functions/daily-fetch/resource.ts.
# Do not set them here.
