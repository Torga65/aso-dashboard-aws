    "@spectrum-icons/workflow": "^4.2.28",
    "ajv": "^8.18.0",
    "aws-amplify": "^6.0.0",
    "next": "14.2.35",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
