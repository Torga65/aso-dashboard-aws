# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
build/

# Amplify — ignore generated artefacts but commit source files
# (Note: cannot negate children of an ignored parent, so we ignore
#  specific generated paths instead of the whole amplify/ directory)
amplify/.amplify/
amplify/generated/
amplify/data/resource-client.ts
.amplify-hosting/

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.*.example

# AWS
.aws-sam/
cdk.out/
cdk.context.json

# Generated by `ampx sandbox` or `ampx generate outputs` — not committed
# (each environment gets its own copy via CI or local sandbox)
amplify_outputs.json

# Cursor (local plans / state — do not commit)
.cursor/

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel
*.tsbuildinfo
next-env.d.ts
