{
  "title": "Broken internal/backlinks suggestion data",
  "description": "SpaceCat suggestion.data: need a broken target link URL (urlFrom optional, used only to resolve relative urlTo)",
  "type": "object",
  "anyOf": [
    { "required": ["urlTo"] },
    { "required": ["url_to"] },
    { "required": ["brokenUrl"] },
    { "required": ["brokenHref"] }
  ],
  "properties": {
    "pageUrl": {
      "type": "string",
      "description": "URL of the page where the broken link appears"
    },
    "urlFrom": {
      "type": "string",
      "description": "Source URL (ESS / SpaceCat camelCase); used to resolve relative urlTo"
    },
    "urlTo": {
      "type": "string",
      "description": "Broken target URL (ESS / SpaceCat camelCase); URL To column"
    },
    "url_from": {
      "type": "string",
      "description": "Source page or domain (snake_case); used to resolve relative urlTo"
    },
    "url_to": {
      "type": "string",
      "description": "Broken link target (snake_case); URL To column"
    },
    "referringDomain": { "type": "string" },
    "referring_domain": { "type": "string" },
    "sourceDomain": { "type": "string" },
    "sourceHost": { "type": "string" },
    "url": { "type": "string" },
    "canonicalUrl": { "type": "string" },
    "brokenUrl": { "type": "string" },
    "brokenHref": { "type": "string" },
    "targetUrl": { "type": "string" },
    "linkUrl": { "type": "string" },
    "destinationUrl": { "type": "string" },
    "toUrl": { "type": "string" },
    "brokenLink": { "type": "string" },
    "statusCode": { "type": "integer" },
    "httpStatus": { "type": "integer" },
    "suggestionValue": { "type": "string" },
    "urlsSuggested": { "type": "array", "items": { "type": "string" } },
    "urlSuggested": { "type": "string" },
    "url_suggested": { "type": "string" },
    "aiSuggestion": { "type": "string" },
    "replacementUrl": { "type": "string" }
  },
  "additionalProperties": true
}
