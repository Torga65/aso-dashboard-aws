# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example
# Copy this file to .env.local for local development.
# Never commit .env.local — it is git-ignored.
# Secrets used by Lambda functions (EXTERNAL_API_KEY, etc.) are stored in
# AWS Secrets Manager via `ampx secret set` and are NOT needed locally
# unless you are invoking the function directly.
# ─────────────────────────────────────────────────────────────────────────────

# Automatically written by `ampx sandbox` or `ampx generate outputs`.
# You can also paste the contents of amplify_outputs.json here as JSON.
# AMPLIFY_OUTPUTS is read by the Amplify client configuration helper.
# Leave blank if you are loading amplify_outputs.json directly from disk.
AMPLIFY_OUTPUTS=

# Optional: override the Amplify environment name when testing locally.
# NEXT_PUBLIC_AMPLIFY_ENV=sandbox

# ─── Validator (SpaceCat) ──────────────────────────────────────────────────────
# Required for the Validator page to fetch sites, opportunities, and suggestions.
# Use either the shared SpaceCat API key or your personal USER_API_KEY.
SPACECAT_API_KEY=your_spacecat_api_key_here
# USER_API_KEY=your_personal_api_key_here

# Optional: override the SpaceCat base URL (defaults to prod).
# SPACECAT_BASE_URL=https://spacecat.experiencecloud.live/api/v1

# Portfolio snapshots (writes public/server/data/snapshots/): npm run snapshot:portfolio:all

# ─── Microsoft Teams Integration (OAuth 2.0) ──────────────────────────────────
# Required for /teams-settings — allows users to connect their MS account and
# auto-sync meeting transcripts. Register an app in Azure AD with delegated
# permissions: OnlineMeeting.Read + OnlineMeetingTranscript.Read + offline_access.
#
# Lambda secrets (TEAMS_CLIENT_ID, TEAMS_CLIENT_SECRET, TEAMS_TENANT_ID) must
# also be set via: npx ampx secret set TEAMS_CLIENT_ID   (etc.)
TEAMS_CLIENT_ID=your_azure_app_client_id
TEAMS_CLIENT_SECRET=your_azure_app_client_secret
TEAMS_TENANT_ID=your_azure_tenant_id
# Callback URL registered in your Azure AD app. In production use your Amplify domain.
TEAMS_REDIRECT_URI=http://localhost:3000/api/teams/callback
